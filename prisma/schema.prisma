generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CLINICIAN
  FOCAL_PERSON
  HOSPITAL_ADMIN
  SYS_ADMIN
}

enum HospitalLevel {
  DISTRICT
  REFERRAL
}


enum SpecialistStatus {
  AVAILABLE
  UNAVAILABLE
}

enum ReferralStatus {
  SUBMITTED
  ADMITTED
  DISCHARGED
  COUNTER_REFERRED
}

enum ReferralUrgency {
  ROUTINE
  URGENT
  EMERGENCY
}

// ==========================================
// MODELS
// ==========================================

model File {
  id           String   @id @default(uuid())
  name         String
  originalName String   @map("original_name")
  url          String
  folder       String
  type         String
  users        User[]   @relation("UserProfilePicture")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("files")
}

model Hospital {
  id            String        @id @default(uuid())
  name          String        @unique
  level         HospitalLevel
  location      String
  contactNumber String?       @map("contact_number")

  users       User[]
  wards       Ward[]
  specialists Specialist[]
  patients    Patient[]

  // Referrals
  referralsSent     Referral[] @relation("ReferringHospital")
  referralsReceived Referral[] @relation("ReceivingHospital")
  auditLogs         AuditLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("hospitals")
}

model User {
  id        String  @id @default(uuid())
  firstName String  @map("first_name")
  lastName  String  @map("last_name")
  email     String  @unique
  password  String
  role      Role    @default(CLINICIAN)
  telephone String?

  hospitalId String?   @map("hospital_id")
  hospital   Hospital? @relation(fields: [hospitalId], references: [id])

  profilePictureId String? @map("profile_picture_id")
  profilePicture   File?   @relation("UserProfilePicture", fields: [profilePictureId], references: [id])

  referralsInitiated Referral[] @relation("InitiatingUser")
  auditLogs          AuditLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Ward {
  id           String   @id @default(uuid())
  name         String
  totalBeds    Int      @map("total_beds")
  occupiedBeds Int      @default(0) @map("occupied_beds")

  hospitalId String   @map("hospital_id")
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  specialists Specialist[]
  referrals   Referral[]

  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([hospitalId, name])
  @@map("wards")
}

model Specialist {
  id             String           @id @default(uuid())
  firstName      String           @map("first_name")
  lastName       String           @map("last_name")
  discipline     String           @default("General Medicine")
  
  wardId         String           @map("ward_id")
  ward           Ward             @relation(fields: [wardId], references: [id], onDelete: Cascade)
  
  status         SpecialistStatus @default(UNAVAILABLE)
  shiftStartTime String?          @map("shift_start_time") // e.g., "08:00"
  shiftEndTime   String?          @map("shift_end_time")   // e.g., "17:00"
  workingDays    String[]         @map("working_days")     // e.g., ["MONDAY", "TUESDAY"]

  hospitalId String   @map("hospital_id")
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt @map("updated_at")

  referrals Referral[]

  @@map("specialists")
}

model Patient {
  id            String   @id @default(uuid())
  nationalId    String   @unique @map("national_id")
  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  dateOfBirth   DateTime @map("date_of_birth")
  gender        String
  insurance     String?
  contactNumber String?  @map("contact_number")
  email         String?
  isActive      Boolean  @default(true) @map("is_active")

  // Address
  cell     String?
  sector   String?
  district String?

  hospitalId String?   @map("hospital_id")
  hospital   Hospital? @relation(fields: [hospitalId], references: [id], onDelete: SetNull)

  referrals Referral[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("patients")
}

model Referral {
  id        String  @id @default(uuid())
  patientId String  @map("patient_id")
  patient   Patient @relation(fields: [patientId], references: [id])

  referringHospitalId String   @map("referring_hospital_id")
  referringHospital   Hospital @relation("ReferringHospital", fields: [referringHospitalId], references: [id])

  receivingHospitalId String   @map("receiving_hospital_id")
  receivingHospital   Hospital @relation("ReceivingHospital", fields: [receivingHospitalId], references: [id])

  initiatedById String @map("initiated_by_id")
  initiatedBy   User   @relation("InitiatingUser", fields: [initiatedById], references: [id])

  status ReferralStatus @default(SUBMITTED)

  reasonForTransfer    String      @map("reason_for_transfer")
  targetWardName       String?     @map("target_ward_name")
  wardId               String?     @map("ward_id")
  ward                 Ward?       @relation(fields: [wardId], references: [id], onDelete: SetNull)
  
  assignedSpecialistId String?     @map("assigned_specialist_id")
  assignedSpecialist   Specialist? @relation(fields: [assignedSpecialistId], references: [id], onDelete: SetNull)
  
  diagnosis            String
  significantFindings  String?     @map("significant_findings")
  proceduresReceived   String?     @map("procedures_received")
  currentMedications   String?     @map("current_medications")
  patientCondition     String?     @map("patient_condition")
  monitoringRequired   String?     @map("monitoring_required")
  preTransferTreatment String?     @map("pre_transfer_treatment")
  transportType        String?     @map("transport_type")
  isEmergency          Boolean     @default(false) @map("is_emergency")
  urgency              ReferralUrgency @default(ROUTINE)
  referringDoctorName  String?     @map("referring_doctor_name")
  referringDoctorContact String?    @map("referring_doctor_contact")
  rejectionReason      String?     @map("rejection_reason")
  expectedAdmissionDate DateTime?  @map("expected_admission_date")

  counterReferral CounterReferral?

  logs          AuditLog[]
  notifications Notification[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("referrals")
}

model CounterReferral {
  id         String   @id @default(uuid())
  referralId String   @unique @map("referral_id")
  referral   Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)

  dischargeNotes       String? @map("discharge_notes")
  followUpInstructions String? @map("follow_up_instructions")
  evidenceUrl          String? @map("evidence_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("counter_referrals")
}

model Notification {
  id          String  @id @default(uuid())
  message     String
  isRead      Boolean @default(false) @map("is_read")
  recipientId String  @map("recipient_id")

  referralId String?   @map("referral_id")
  referral   Referral? @relation(fields: [referralId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

model AuditLog {
  id            String  @id @default(uuid())
  action        String
  entity        String? // e.g., "Referral", "BedCapacity"
  entityId      String? @map("entity_id")
  details       String?
  performedById String? @map("performed_by_id")
  performedBy   User?   @relation(fields: [performedById], references: [id], onDelete: SetNull)

  referralId String?   @map("referral_id")
  referral   Referral? @relation(fields: [referralId], references: [id], onDelete: SetNull)

  hospitalId String?   @map("hospital_id")
  hospital   Hospital? @relation(fields: [hospitalId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}
